                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin>
                  </Label>
                  <Button fx:id="btnClear" mnemonicParsing="false" onAction="#doClearText" prefHeight="27.0" prefWidth="85.0" text="Clear text">
                     <HBox.margin>
